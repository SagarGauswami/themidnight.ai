---
const socials = [
  {
    href: 'https://linkedin.com',
    label: 'LinkedIn',
    icon: `<svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>`
  },
  {
    href: 'https://twitter.com',
    label: 'Twitter / X',
    icon: `<svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>`
  },
  {
    href: 'https://instagram.com',
    label: 'Instagram',
    icon: `<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>`
  },
];
---

<footer class="footer">

  <!-- Animated radial background -->
  <div class="footer__radial"></div>
  <div class="footer__grid-bg"></div>

  <div class="container">

    <!-- ── TOP: Liquid Glass Cards Row ── -->
    <div class="footer__cards-row">

      <!-- Brand card -->
      <div class="lg-card lg-card--brand">
        <div class="lg-card__inner">
          <div class="lg-card__shine"></div>
          <img
            src="https://themidnight.in/media/images/logo.svg"
            alt="Midnight Digital"
            width="130" height="34"
            loading="lazy"
            class="footer__logo-img"
          />
          <p class="footer__tagline">
            We never sleep until we deliver what we committed.
          </p>
          <div class="footer__avail">
            <span class="avail-dot"></span>
            Available for new projects
          </div>
        </div>
      </div>

      <!-- Contact card -->
      <div class="lg-card lg-card--contact">
        <div class="lg-card__inner">
          <div class="lg-card__shine"></div>
          <h6 class="lg-card__title">Contact Us</h6>
          <div class="contact-list">
            <a href="mailto:sagar@themidnight.in" class="contact-item">
              <span class="contact-icon">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </span>
              sagar@themidnight.in
            </a>
            <a href="https://themidnight.in" target="_blank" class="contact-item">
              <span class="contact-icon">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15 15 0 0 1 0 20M12 2a15 15 0 0 0 0 20"/></svg>
              </span>
              themidnight.in
            </a>
            <a href="#contact" class="contact-item">
              <span class="contact-icon">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              </span>
              Start a Conversation
            </a>
          </div>
        </div>
      </div>

      <!-- Social card -->
      <div class="lg-card lg-card--social">
        <div class="lg-card__inner">
          <div class="lg-card__shine"></div>
          <h6 class="lg-card__title">Follow Us</h6>
          <div class="social-list">
            {socials.map(s => (
              <a href={s.href} class="social-pill" aria-label={s.label} target="_blank" rel="noopener">
                <span set:html={s.icon}></span>
                <span>{s.label}</span>
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Quick links card -->
      <div class="lg-card lg-card--links">
        <div class="lg-card__inner">
          <div class="lg-card__shine"></div>
          <h6 class="lg-card__title">Quick Links</h6>
          <ul class="quick-links">
            <li><a href="#services">AI Solutions</a></li>
            <li><a href="#ai-products">AI Products</a></li>
            <li><a href="#hire-devs">Hire AI Devs</a></li>
            <li><a href="#why-us">About Us</a></li>
            <li><a href="#contact">Get a Quote</a></li>
          </ul>
        </div>
      </div>

    </div>

    <!-- ── BIG COMPANY NAME ── -->
    <div class="footer__bigname-wrap">
      <div class="footer__bigname">
        <span class="bigname-text">Midnight Digital</span>
        <span class="bigname-sub">Pvt. Ltd.</span>
      </div>
      <div class="footer__bigname-glow"></div>
    </div>

    <!-- ── BOTTOM BAR ── -->
    <div class="footer__bottom">
      <p class="footer__copy">© 2025 Midnight Digital Pvt. Ltd. All rights reserved.</p>
      <p class="footer__built">Built with <span class="orange">Astro</span></p>
    </div>

  </div>
</footer>

<style>
/* ── BASE ── */
.footer {
  position: relative;
  overflow: hidden;
  background: #050505;
  padding: 80px 0 0;
}

/* Radial bg glow */
.footer__radial {
  position: absolute;
  bottom: 0; left: 50%;
  transform: translateX(-50%);
  width: 900px; height: 500px;
  background: radial-gradient(ellipse at center bottom,
    rgba(247,150,32,0.1) 0%,
    rgba(247,150,32,0.04) 40%,
    transparent 70%
  );
  pointer-events: none;
  z-index: 0;
}

/* Subtle grid */
.footer__grid-bg {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(247,150,32,0.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(247,150,32,0.025) 1px, transparent 1px);
  background-size: 48px 48px;
  z-index: 0;
  mask-image: linear-gradient(to bottom, transparent, rgba(0,0,0,0.5) 30%, rgba(0,0,0,0.5) 70%, transparent);
}

.footer .container { position: relative; z-index: 1; }

/* ── LIQUID GLASS CARDS ── */
.footer__cards-row {
  display: grid;
  grid-template-columns: 1.4fr 1.2fr 1fr 1fr;
  gap: 16px;
  margin-bottom: 56px;
}

/* The glass card shell */
.lg-card {
  border-radius: 20px;
  padding: 2px; /* border thickness via gradient wrapper */
  background: linear-gradient(
    135deg,
    rgba(255,255,255,0.12) 0%,
    rgba(255,255,255,0.03) 40%,
    rgba(247,150,32,0.12) 100%
  );
  animation: border-glow 4s ease-in-out infinite;
  transition: transform 0.4s cubic-bezier(0.34,1.56,0.64,1);
}
.lg-card:hover {
  transform: translateY(-6px) scale(1.01);
}

/* Inner frosted glass */
.lg-card__inner {
  position: relative;
  overflow: hidden;
  border-radius: 18px;
  background: rgba(255,255,255,0.04);
  backdrop-filter: blur(24px) saturate(180%);
  -webkit-backdrop-filter: blur(24px) saturate(180%);
  padding: 28px;
  height: 100%;
}

/* Apple-style inner shine — top highlight */
.lg-card__shine {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg,
    transparent 0%,
    rgba(255,255,255,0.5) 30%,
    rgba(255,255,255,0.9) 50%,
    rgba(255,255,255,0.5) 70%,
    transparent 100%
  );
  animation: shimmer 4s linear infinite;
  background-size: 200% 100%;
}

/* Animated inner light refraction */
.lg-card__inner::before {
  content: '';
  position: absolute;
  top: -60%; left: -60%;
  width: 220%; height: 220%;
  background: radial-gradient(ellipse at 30% 20%,
    rgba(255,255,255,0.06) 0%,
    transparent 60%
  );
  animation: lg-refract 8s ease-in-out infinite alternate;
  pointer-events: none;
}

@keyframes lg-refract {
  0%   { transform: translate(0, 0) rotate(0deg); }
  100% { transform: translate(20px, 20px) rotate(15deg); }
}

/* Card titles */
.lg-card__title {
  font-size: 0.68rem;
  font-weight: 800;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--color-orange);
  margin-bottom: 18px;
}

/* ── BRAND CARD ── */
.footer__logo-img {
  height: 32px;
  width: auto;
  margin-bottom: 16px;
  filter: brightness(1.1);
}
.footer__tagline {
  font-size: 0.82rem;
  color: rgba(255,255,255,0.45);
  line-height: 1.75;
  font-style: italic;
  margin-bottom: 20px;
  border-left: 2px solid rgba(247,150,32,0.4);
  padding-left: 12px;
}
.footer__avail {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 5px 13px;
  background: rgba(34,197,94,0.08);
  border: 1px solid rgba(34,197,94,0.2);
  border-radius: 20px;
  font-size: 0.7rem;
  font-weight: 600;
  color: #22c55e;
}
.avail-dot {
  width: 6px; height: 6px;
  background: #22c55e;
  border-radius: 50%;
  box-shadow: 0 0 6px #22c55e;
  animation: pulse-glow 2.5s ease-in-out infinite;
  flex-shrink: 0;
}

/* ── CONTACT CARD ── */
.contact-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.contact-item {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 0.82rem;
  color: rgba(255,255,255,0.55);
  transition: color 0.3s, gap 0.3s;
  font-weight: 500;
}
.contact-item:hover {
  color: var(--color-orange);
  gap: 14px;
}
.contact-icon {
  width: 28px; height: 28px;
  background: rgba(247,150,32,0.08);
  border: 1px solid rgba(247,150,32,0.18);
  border-radius: 7px;
  display: flex; align-items: center; justify-content: center;
  color: var(--color-orange);
  flex-shrink: 0;
  transition: background 0.3s;
}
.contact-item:hover .contact-icon {
  background: rgba(247,150,32,0.18);
}

/* ── SOCIAL CARD ── */
.social-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.social-pill {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 9px 14px;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 10px;
  font-size: 0.82rem;
  font-weight: 500;
  color: rgba(255,255,255,0.55);
  transition: all 0.3s;
}
.social-pill:hover {
  background: rgba(247,150,32,0.1);
  border-color: rgba(247,150,32,0.35);
  color: var(--color-orange);
  transform: translateX(4px);
}

/* ── QUICK LINKS CARD ── */
.quick-links {
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.quick-links li a {
  font-size: 0.84rem;
  color: rgba(255,255,255,0.45);
  transition: color 0.3s, padding-left 0.3s;
  display: inline-block;
  padding-left: 0;
}
.quick-links li a::before {
  content: '→ ';
  color: var(--color-orange);
  opacity: 0;
  transition: opacity 0.3s;
  font-size: 0.75rem;
}
.quick-links li a:hover {
  color: var(--color-white);
  padding-left: 4px;
}
.quick-links li a:hover::before { opacity: 1; }

/* ── BIG COMPANY NAME ── */
.footer__bigname-wrap {
  position: relative;
  text-align: center;
  padding: 48px 0 0;
  border-top: 1px solid rgba(255,255,255,0.05);
  overflow: hidden;
}
.footer__bigname {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
  line-height: 1;
}
.bigname-text {
  font-family: var(--font-primary);
  font-size: clamp(3rem, 9vw, 8rem);
  font-weight: 900;
  letter-spacing: -0.03em;
  text-transform: uppercase;
  background: linear-gradient(
    180deg,
    rgba(255,255,255,0.85) 0%,
    rgba(255,255,255,0.25) 60%,
    rgba(255,255,255,0.05) 100%
  );
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  display: block;
  animation: fade-in-up 1s ease forwards;
}
.bigname-sub {
  font-family: var(--font-primary);
  font-size: clamp(1rem, 2.5vw, 2rem);
  font-weight: 400;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: rgba(247,150,32,0.7);
  display: block;
  margin-top: 4px;
  animation: fade-in-up 1s ease 0.2s forwards;
  opacity: 0;
}

/* Orange glow behind big text */
.footer__bigname-glow {
  position: absolute;
  bottom: -30px;
  left: 50%;
  transform: translateX(-50%);
  width: 60%;
  height: 80px;
  background: radial-gradient(ellipse, rgba(247,150,32,0.15) 0%, transparent 70%);
  animation: pulse-glow 4s ease-in-out infinite;
}

/* ── BOTTOM BAR ── */
.footer__bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 0 32px;
  flex-wrap: wrap;
  gap: 10px;
}
.footer__copy,
.footer__built {
  font-size: 0.75rem;
  color: rgba(255,255,255,0.2);
}
.footer__built .orange {
  color: var(--color-orange);
  font-weight: 700;
}

/* ── RESPONSIVE ── */
@media (max-width: 1024px) {
  .footer__cards-row { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 600px) {
  .footer__cards-row { grid-template-columns: 1fr; }
  .bigname-text { font-size: clamp(2.2rem, 12vw, 5rem); }
  .footer__bottom { flex-direction: column; align-items: center; text-align: center; }
}
</style>
