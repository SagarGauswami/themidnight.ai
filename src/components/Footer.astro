---
const socials = [
  { href: 'https://linkedin.com', label: 'LinkedIn', icon: `<svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>` },
  { href: 'https://twitter.com', label: 'Twitter', icon: `<svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>` },
  { href: 'https://instagram.com', label: 'Instagram', icon: `<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>` },
];

const links = {
  Services: ['AI Solutions', 'AI Product Dev', 'Hire AI Devs', 'AI Consulting'],
  Company: ['About Us', 'Our Process', 'Portfolio', 'Careers'],
  Legal: ['Privacy Policy', 'Terms of Service', 'NDA Template'],
};
---

<footer class="footer">
  <div class="footer__top-line"></div>
  <div class="container">
    <div class="footer__grid">
      <!-- Brand -->
      <div class="footer__brand">
        <a href="/" class="footer__logo">
          <img src="https://themidnight.in/media/images/logo.svg" alt="Midnight Digital" width="140" height="36" loading="lazy" />
        </a>
        <p class="footer__tagline">
          We never go to sleep until we deliver what we committed.
        </p>
        <div class="footer__socials">
          {socials.map(s => (
            <a href={s.href} class="social-btn" aria-label={s.label} target="_blank" rel="noopener" set:html={s.icon}></a>
          ))}
        </div>
        <div class="footer__badge">
          <span class="footer-badge-dot"></span>
          Available for new projects
        </div>
      </div>

      <!-- Links -->
      {Object.entries(links).map(([group, items]) => (
        <div class="footer__links-col">
          <h6 class="footer__col-title">{group}</h6>
          <ul>
            {items.map(item => (
              <li><a href="#contact" class="footer__link">{item}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="footer__bottom">
      <p class="footer__copy">© 2025 Midnight Digital Pvt Ltd. All rights reserved.</p>
      <p class="footer__made">
        Built with ❤️ using <span style="color: var(--color-orange); font-weight:700;">Astro</span>
      </p>
    </div>
  </div>
</footer>

<style>
.footer {
  background: rgba(0,0,0,0.6);
  border-top: 1px solid var(--color-border);
  padding: 72px 0 32px;
}
.footer__top-line {
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--color-orange), transparent);
  margin-bottom: 0;
}

.footer__grid {
  display: grid;
  grid-template-columns: 1.6fr 1fr 1fr 1fr;
  gap: 48px;
  margin-bottom: 56px;
}
.footer__logo img {
  height: 34px;
  width: auto;
  margin-bottom: 16px;
  filter: brightness(1.05);
}
.footer__tagline {
  font-size: 0.85rem;
  color: rgba(255,255,255,0.45);
  line-height: 1.7;
  margin-bottom: 24px;
  font-style: italic;
}
.footer__socials {
  display: flex;
  gap: 10px;
  margin-bottom: 20px;
}
.social-btn {
  width: 38px; height: 38px;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  color: rgba(255,255,255,0.55);
  transition: var(--transition);
}
.social-btn:hover {
  background: rgba(247,150,32,0.12);
  border-color: rgba(247,150,32,0.4);
  color: var(--color-orange);
  transform: translateY(-2px);
}
.footer__badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 6px 14px;
  background: rgba(34,197,94,0.08);
  border: 1px solid rgba(34,197,94,0.2);
  border-radius: 20px;
  font-size: 0.72rem;
  font-weight: 600;
  color: #22c55e;
}
.footer-badge-dot {
  width: 6px; height: 6px;
  background: #22c55e;
  border-radius: 50%;
  animation: pulse-glow 2.5s ease-in-out infinite;
  box-shadow: 0 0 6px #22c55e;
}

.footer__col-title {
  font-size: 0.72rem;
  font-weight: 800;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--color-orange);
  margin-bottom: 20px;
}
.footer__links-col ul {
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.footer__link {
  font-size: 0.85rem;
  color: rgba(255,255,255,0.5);
  transition: color 0.3s;
}
.footer__link:hover { color: var(--color-white); }

.footer__bottom {
  padding-top: 28px;
  border-top: 1px solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 12px;
}
.footer__copy, .footer__made {
  font-size: 0.8rem;
  color: rgba(255,255,255,0.3);
}

@media (max-width: 900px) {
  .footer__grid { grid-template-columns: 1fr 1fr; gap: 36px; }
  .footer__brand { grid-column: span 2; }
}
@media (max-width: 540px) {
  .footer__grid { grid-template-columns: 1fr; }
  .footer__brand { grid-column: span 1; }
  .footer__bottom { flex-direction: column; text-align: center; }
}
</style>
