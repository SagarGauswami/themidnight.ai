---
---

<footer class="footer" id="footer">

  <!-- ══════════════════════════════════════
       TOP CTA STRIP
  ══════════════════════════════════════ -->
  <div class="footer__cta-strip">
    <div class="footer__cta-bg"></div>
    <div class="container footer__cta-inner">
      <div class="footer__cta-text">
        <span class="footer__cta-eyebrow">Ready to build with AI?</span>
        <h2 class="footer__cta-headline">Let's Create Something<br/><em>Extraordinary</em></h2>
      </div>
      <div class="footer__cta-actions">
        <a href="#contact" class="btn-primary">
          Start a Project
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="mailto:sagar@themidnight.in" class="footer__cta-email">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          sagar@themidnight.in
        </a>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════
       MAIN FOOTER BODY
  ══════════════════════════════════════ -->
  <div class="footer__body">
    <div class="container">
      <div class="footer__cols">

        <!-- COL 1 ── Brand -->
        <div class="fcol fcol--brand">
          <a href="/" class="fcol__logo">
            <img
              src="https://themidnight.in/media/images/logo.svg"
              alt="Midnight Digital"
              width="136" height="36"
              loading="lazy"
            />
          </a>
          <p class="fcol__desc">
            An AI-first studio crafting intelligent solutions,<br/>
            products, and teams — on demand.
          </p>

          <!-- Socials -->
          <div class="fcol__socials">
            <a href="https://linkedin.com" aria-label="LinkedIn" target="_blank" rel="noopener" class="fsocial">
              <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
            <a href="https://instagram.com" aria-label="Instagram" target="_blank" rel="noopener" class="fsocial">
              <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
            </a>
            <a href="https://twitter.com" aria-label="Twitter / X" target="_blank" rel="noopener" class="fsocial">
              <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
            </a>
          </div>
        </div>

        <!-- COL 2 ── Services -->
        <div class="fcol">
          <h6 class="fcol__heading">Services</h6>
          <nav class="fcol__nav">
            <a href="#services">AI Solutions</a>
            <a href="#ai-products">AI Product Development</a>
            <a href="#hire-devs">AI Developers on Rent</a>
            <a href="#contact">AI Strategy Consulting</a>
          </nav>
        </div>

        <!-- COL 3 ── Company -->
        <div class="fcol">
          <h6 class="fcol__heading">Company</h6>
          <nav class="fcol__nav">
            <a href="#why-us">About Us</a>
            <a href="#services">Our Process</a>
            <a href="#ai-products">Portfolio</a>
            <a href="#contact">Careers</a>
          </nav>
        </div>

        <!-- COL 4 ── Contact -->
        <div class="fcol">
          <h6 class="fcol__heading">Get in Touch</h6>
          <div class="fcol__contact">
            <a href="mailto:sagar@themidnight.in" class="fcontact-link">
              <div class="fcontact-icon">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </div>
              <div>
                <span class="fcontact-label">Email us</span>
                <span class="fcontact-value">sagar@themidnight.in</span>
              </div>
            </a>
            <a href="https://themidnight.in" target="_blank" class="fcontact-link">
              <div class="fcontact-icon">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15 15 0 0 1 0 20M12 2a15 15 0 0 0 0 20"/></svg>
              </div>
              <div>
                <span class="fcontact-label">Website</span>
                <span class="fcontact-value">themidnight.in</span>
              </div>
            </a>
            <div class="fcontact-avail">
              <span class="avail-dot"></span>
              Available for projects
            </div>
          </div>
        </div>

      </div><!-- /cols -->

      <!-- Bottom bar -->
      <div class="footer__bar">
        <p class="footer__copy">© 2025 Midnight Digital Pvt. Ltd. All rights reserved.</p>
        <p class="footer__built">
          Built with&nbsp;<span>Astro</span>
        </p>
      </div>

    </div>
  </div>

  <!-- ══════════════════════════════════════
       MARQUEE — scrolling company name
  ══════════════════════════════════════ -->
  <div class="footer__marquee-section">
    <div class="footer__marquee-mask">
      <div class="footer__marquee-track" aria-hidden="true">
        <!-- 8× copies for seamless infinite scroll -->
        {[...Array(8)].map(() => (
          <span class="marquee-item">
            <span class="mq-filled">Midnight Digital</span>
            <span class="mq-dot">✦</span>
            <span class="mq-outline">Pvt. Ltd.</span>
            <span class="mq-dot">✦</span>
          </span>
        ))}
      </div>
    </div>
  </div>

</footer>

<style>
/* ═══════════ BASE ═══════════ */
.footer {
  background: #060606;
  overflow: hidden;
}

/* ═══════════ CTA STRIP ═══════════ */
.footer__cta-strip {
  position: relative;
  padding: 72px 0;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  overflow: hidden;
}
.footer__cta-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 60% 120% at 80% 50%, rgba(247,150,32,0.12) 0%, transparent 70%),
    linear-gradient(135deg, rgba(247,150,32,0.04) 0%, transparent 60%);
}
/* animated shimmer border-top */
.footer__cta-strip::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1.5px;
  background: linear-gradient(90deg, transparent, var(--color-orange), rgba(255,255,255,0.8), var(--color-orange), transparent);
  background-size: 200% 100%;
  animation: shimmer 3.5s linear infinite;
}
.footer__cta-inner {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 40px;
  flex-wrap: wrap;
}
.footer__cta-eyebrow {
  display: block;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--color-orange);
  margin-bottom: 12px;
}
.footer__cta-headline {
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  font-weight: 900;
  line-height: 1.15;
  color: var(--color-white);
  letter-spacing: -0.02em;
}
.footer__cta-headline em {
  font-style: normal;
  background: linear-gradient(135deg, var(--color-orange) 0%, #ffbd59 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.footer__cta-actions {
  display: flex;
  align-items: center;
  gap: 20px;
  flex-wrap: wrap;
  flex-shrink: 0;
}
.footer__cta-email {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 0.875rem;
  font-weight: 600;
  color: rgba(255,255,255,0.55);
  transition: color 0.3s;
}
.footer__cta-email:hover { color: var(--color-orange); }

/* ═══════════ BODY ═══════════ */
.footer__body { padding: 56px 0 0; }

.footer__cols {
  display: grid;
  grid-template-columns: 1.6fr 1fr 1fr 1.3fr;
  gap: 48px;
  padding-bottom: 48px;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}

/* ── Brand col ── */
.fcol__logo img {
  height: 32px;
  width: auto;
  display: block;
  margin-bottom: 18px;
  filter: brightness(1.1);
}
.fcol__desc {
  font-size: 0.85rem;
  color: rgba(255,255,255,0.38);
  line-height: 1.8;
  margin-bottom: 24px;
}
.fcol__socials {
  display: flex;
  gap: 8px;
}
.fsocial {
  width: 36px; height: 36px;
  display: flex; align-items: center; justify-content: center;
  border-radius: 9px;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  color: rgba(255,255,255,0.45);
  transition: all 0.28s;
}
.fsocial:hover {
  background: rgba(247,150,32,0.12);
  border-color: rgba(247,150,32,0.4);
  color: var(--color-orange);
  transform: translateY(-3px);
  box-shadow: 0 8px 20px rgba(247,150,32,0.12);
}

/* ── Nav cols ── */
.fcol__heading {
  font-size: 0.68rem;
  font-weight: 800;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.25);
  margin-bottom: 20px;
}
.fcol__nav {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.fcol__nav a {
  font-size: 0.875rem;
  color: rgba(255,255,255,0.5);
  transition: color 0.25s, transform 0.25s;
  display: inline-block;
  position: relative;
  padding-left: 0;
}
.fcol__nav a::after {
  content: '';
  position: absolute;
  bottom: -2px; left: 0;
  width: 0; height: 1px;
  background: var(--color-orange);
  transition: width 0.3s;
}
.fcol__nav a:hover {
  color: var(--color-white);
  transform: translateX(4px);
}
.fcol__nav a:hover::after { width: 100%; }

/* ── Contact col ── */
.fcol__contact {
  display: flex;
  flex-direction: column;
  gap: 14px;
}
.fcontact-link {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 11px 14px;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 11px;
  transition: all 0.3s;
}
.fcontact-link:hover {
  background: rgba(247,150,32,0.06);
  border-color: rgba(247,150,32,0.28);
  transform: translateX(3px);
}
.fcontact-icon {
  width: 30px; height: 30px;
  background: rgba(247,150,32,0.08);
  border: 1px solid rgba(247,150,32,0.18);
  border-radius: 7px;
  display: flex; align-items: center; justify-content: center;
  color: var(--color-orange);
  flex-shrink: 0;
}
.fcontact-label {
  display: block;
  font-size: 0.68rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: rgba(255,255,255,0.3);
  margin-bottom: 2px;
}
.fcontact-value {
  display: block;
  font-size: 0.82rem;
  font-weight: 600;
  color: rgba(255,255,255,0.7);
}
.fcontact-avail {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 6px 14px;
  background: rgba(34,197,94,0.07);
  border: 1px solid rgba(34,197,94,0.18);
  border-radius: 20px;
  font-size: 0.7rem;
  font-weight: 600;
  color: #22c55e;
  width: fit-content;
}
.avail-dot {
  width: 6px; height: 6px;
  background: #22c55e;
  border-radius: 50%;
  box-shadow: 0 0 6px #22c55e;
  animation: pulse-glow 2.5s ease-in-out infinite;
  flex-shrink: 0;
}

/* ══ BOTTOM BAR ══ */
.footer__bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 0 32px;
  flex-wrap: wrap;
  gap: 10px;
}
.footer__copy { font-size: 0.75rem; color: rgba(255,255,255,0.2); }
.footer__built { font-size: 0.75rem; color: rgba(255,255,255,0.2); }
.footer__built span { color: var(--color-orange); font-weight: 700; }

/* ═══════════ MARQUEE ═══════════ */
.footer__marquee-section {
  border-top: 1px solid rgba(247,150,32,0.1);
  background: rgba(247,150,32,0.03);
  padding: 20px 0;
  overflow: hidden;
  position: relative;
}
/* Edge fade */
.footer__marquee-section::before,
.footer__marquee-section::after {
  content: '';
  position: absolute;
  top: 0; bottom: 0;
  width: 10%;
  z-index: 2;
  pointer-events: none;
}
.footer__marquee-section::before {
  left: 0;
  background: linear-gradient(90deg, #060606 0%, transparent 100%);
}
.footer__marquee-section::after {
  right: 0;
  background: linear-gradient(270deg, #060606 0%, transparent 100%);
}

.footer__marquee-mask { overflow: hidden; }

.footer__marquee-track {
  display: flex;
  width: max-content;
  animation: marquee-rtl 25s linear infinite;
  will-change: transform;
}
.footer__marquee-track:hover { animation-play-state: paused; }

@keyframes marquee-rtl {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}

.marquee-item {
  display: inline-flex;
  align-items: center;
  gap: 24px;
  padding: 0 24px;
  white-space: nowrap;
}
.mq-filled {
  font-family: var(--font-primary);
  font-size: clamp(2rem, 4.5vw, 3.8rem);
  font-weight: 900;
  letter-spacing: -0.02em;
  text-transform: uppercase;
  color: var(--color-white);
  opacity: 0.12;
}
.mq-outline {
  font-family: var(--font-primary);
  font-size: clamp(2rem, 4.5vw, 3.8rem);
  font-weight: 900;
  letter-spacing: -0.02em;
  text-transform: uppercase;
  color: transparent;
  -webkit-text-stroke: 1.5px rgba(247,150,32,0.45);
}
.mq-dot {
  font-size: 1.2rem;
  color: var(--color-orange);
  opacity: 0.4;
}

/* ═══════════ RESPONSIVE ═══════════ */
@media (max-width: 1024px) {
  .footer__cols { grid-template-columns: 1fr 1fr; gap: 36px; }
  .fcol--brand { grid-column: span 2; }
}
@media (max-width: 640px) {
  .footer__cta-inner { flex-direction: column; gap: 28px; }
  .footer__cols { grid-template-columns: 1fr; gap: 28px; }
  .fcol--brand { grid-column: span 1; }
  .footer__bar { flex-direction: column; align-items: flex-start; }
}
</style>
