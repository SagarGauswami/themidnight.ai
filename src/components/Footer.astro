---
const socials = [
  {
    href: 'https://linkedin.com',
    label: 'LinkedIn',
    icon: `<svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>`
  },
  {
    href: 'https://twitter.com',
    label: 'Twitter/X',
    icon: `<svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>`
  },
  {
    href: 'https://instagram.com',
    label: 'Instagram',
    icon: `<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>`
  },
];
---

<footer class="footer">
  <!-- Animated top border -->
  <div class="footer__shine"></div>

  <!-- Main content -->
  <div class="container">
    <!-- Top row: Brand + Newsletter CTA -->
    <div class="footer__top">
      <div class="footer__brand">
        <a href="/" class="footer__logo">
          <img src="https://themidnight.in/media/images/logo.svg" alt="Midnight Digital" width="140" height="36" loading="lazy" />
        </a>
        <p class="footer__tagline">
          "We never go to sleep until we<br/>deliver what we committed."
        </p>
        <div class="footer__socials">
          {socials.map(s => (
            <a href={s.href} class="social-btn" aria-label={s.label} target="_blank" rel="noopener" set:html={s.icon}></a>
          ))}
        </div>
      </div>

      <div class="footer__links-group">
        <div class="footer__col">
          <h6 class="footer__col-title">Services</h6>
          <ul>
            <li><a href="#services">AI Solutions</a></li>
            <li><a href="#ai-products">AI Product Dev</a></li>
            <li><a href="#hire-devs">Hire AI Devs</a></li>
            <li><a href="#contact">AI Consulting</a></li>
          </ul>
        </div>
        <div class="footer__col">
          <h6 class="footer__col-title">Company</h6>
          <ul>
            <li><a href="#why-us">About Us</a></li>
            <li><a href="#services">Our Process</a></li>
            <li><a href="#ai-products">Portfolio</a></li>
            <li><a href="#contact">Careers</a></li>
          </ul>
        </div>
        <div class="footer__col">
          <h6 class="footer__col-title">Contact</h6>
          <ul>
            <li><a href="mailto:sagar@themidnight.in">sagar@themidnight.in</a></li>
            <li><a href="https://themidnight.in" target="_blank">themidnight.in</a></li>
            <li><a href="#contact">Get a Quote</a></li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Divider with glow -->
    <div class="footer__divider">
      <div class="footer__divider-line"></div>
      <div class="footer__divider-dot"></div>
      <div class="footer__divider-line"></div>
    </div>

    <!-- Bottom row -->
    <div class="footer__bottom">
      <p class="footer__copy">© 2025 Midnight Digital Pvt Ltd. All rights reserved.</p>
      <div class="footer__badges">
        <div class="footer__avail-badge">
          <span class="avail-dot"></span>
          Available for new projects
        </div>
        <span class="footer__sep">·</span>
        <p class="footer__made">Built with <span class="orange">Astro</span></p>
      </div>
    </div>
  </div>

  <!-- Background decoration -->
  <div class="footer__bg-glow"></div>
</footer>

<style>
.footer {
  position: relative;
  overflow: hidden;
  background: #050505;
  padding: 0 0 32px;
}

/* Animated top shine border */
.footer__shine {
  height: 2px;
  background: linear-gradient(90deg,
    transparent 0%,
    var(--color-orange) 30%,
    #fff 50%,
    var(--color-orange) 70%,
    transparent 100%
  );
  background-size: 200% 100%;
  animation: shimmer 3s linear infinite;
  margin-bottom: 64px;
}

/* Background glow */
.footer__bg-glow {
  position: absolute;
  bottom: -120px;
  left: 50%;
  transform: translateX(-50%);
  width: 600px;
  height: 300px;
  background: radial-gradient(ellipse, rgba(247,150,32,0.06) 0%, transparent 70%);
  pointer-events: none;
}

/* Top section: brand + links */
.footer__top {
  display: grid;
  grid-template-columns: 1fr 1.8fr;
  gap: 64px;
  align-items: start;
  margin-bottom: 48px;
}

/* Brand */
.footer__logo img {
  height: 34px;
  width: auto;
  margin-bottom: 20px;
  filter: brightness(1.1);
  display: block;
}
.footer__tagline {
  font-size: 0.88rem;
  color: rgba(255,255,255,0.4);
  line-height: 1.8;
  font-style: italic;
  margin-bottom: 24px;
  border-left: 2px solid rgba(247,150,32,0.4);
  padding-left: 14px;
}
.footer__socials {
  display: flex;
  gap: 10px;
}
.social-btn {
  width: 38px; height: 38px;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  color: rgba(255,255,255,0.5);
  transition: var(--transition);
}
.social-btn:hover {
  background: rgba(247,150,32,0.12);
  border-color: rgba(247,150,32,0.4);
  color: var(--color-orange);
  transform: translateY(-3px);
  box-shadow: 0 8px 20px rgba(247,150,32,0.15);
}

/* Links group */
.footer__links-group {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px;
}
.footer__col-title {
  font-size: 0.7rem;
  font-weight: 800;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--color-orange);
  margin-bottom: 18px;
}
.footer__col ul {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.footer__col ul li a {
  font-size: 0.85rem;
  color: rgba(255,255,255,0.45);
  transition: color 0.3s, padding-left 0.3s;
  display: inline-block;
}
.footer__col ul li a:hover {
  color: var(--color-white);
  padding-left: 6px;
}

/* Glow divider */
.footer__divider {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 28px;
}
.footer__divider-line {
  flex: 1;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.08));
}
.footer__divider-line:last-child {
  background: linear-gradient(270deg, transparent, rgba(255,255,255,0.08));
}
.footer__divider-dot {
  width: 6px; height: 6px;
  background: var(--color-orange);
  border-radius: 50%;
  box-shadow: 0 0 10px var(--color-orange);
  flex-shrink: 0;
}

/* Bottom row */
.footer__bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 16px;
}
.footer__copy {
  font-size: 0.8rem;
  color: rgba(255,255,255,0.25);
}
.footer__badges {
  display: flex;
  align-items: center;
  gap: 14px;
  flex-wrap: wrap;
}
.footer__avail-badge {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 5px 14px;
  background: rgba(34,197,94,0.07);
  border: 1px solid rgba(34,197,94,0.18);
  border-radius: 20px;
  font-size: 0.72rem;
  font-weight: 600;
  color: #22c55e;
}
.avail-dot {
  width: 6px; height: 6px;
  background: #22c55e;
  border-radius: 50%;
  animation: pulse-glow 2.5s ease-in-out infinite;
  box-shadow: 0 0 6px #22c55e;
}
.footer__sep {
  color: rgba(255,255,255,0.2);
}
.footer__made {
  font-size: 0.8rem;
  color: rgba(255,255,255,0.25);
}
.footer__made .orange {
  color: var(--color-orange);
  font-weight: 700;
}

/* Responsive */
@media (max-width: 900px) {
  .footer__top { grid-template-columns: 1fr; gap: 36px; }
  .footer__links-group { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width: 600px) {
  .footer__links-group { grid-template-columns: repeat(2, 1fr); gap: 24px; }
  .footer__bottom { flex-direction: column; align-items: flex-start; }
}
@media (max-width: 380px) {
  .footer__links-group { grid-template-columns: 1fr; }
}
</style>
