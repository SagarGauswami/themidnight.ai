</footer>

<style>
/* ── FOOTER BASE ── */
.footer {
  background: #050505;
  border-top: 1px solid rgba(255,255,255,0.06);
  overflow: hidden;
}

.footer__top-line {
  height: 2px;
  background: linear-gradient(90deg, transparent 0%, var(--color-orange) 30%, #fff 50%, var(--color-orange) 70%, transparent 100%);
  background-size: 200% 100%;
  animation: shimmer 3s linear infinite;
}

/* ── 3-COLUMN GRID ── */
.footer__grid {
  display: grid;
  grid-template-columns: 1.4fr 1fr 1.2fr;
  gap: 48px;
  padding: 56px 0 40px;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}

/* ── COL SHARED ── */
.footer__col-title {
  font-size: 0.68rem;
  font-weight: 800;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--color-orange);
  margin-bottom: 20px;
}

/* ── COL 1: Logo + Address ── */
.footer__logo img {
  height: 34px;
  width: auto;
  display: block;
  margin-bottom: 16px;
  filter: brightness(1.1);
}
.footer__tagline {
  font-size: 0.83rem;
  color: rgba(255,255,255,0.4);
  line-height: 1.75;
  font-style: italic;
  margin-bottom: 24px;
  padding-left: 12px;
  border-left: 2px solid rgba(247,150,32,0.4);
}
.footer__address {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 22px;
}
.addr-item {
  display: flex;
  align-items: center;
  gap: 9px;
  font-size: 0.82rem;
  color: rgba(255,255,255,0.45);
}
.addr-item a {
  color: rgba(255,255,255,0.45);
  transition: color 0.3s;
}
.addr-item a:hover { color: var(--color-orange); }

.footer__avail {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 5px 14px;
  background: rgba(34,197,94,0.07);
  border: 1px solid rgba(34,197,94,0.2);
  border-radius: 20px;
  font-size: 0.7rem;
  font-weight: 600;
  color: #22c55e;
}
.avail-dot {
  width: 6px; height: 6px;
  background: #22c55e;
  border-radius: 50%;
  box-shadow: 0 0 6px #22c55e;
  animation: pulse-glow 2.5s ease-in-out infinite;
  flex-shrink: 0;
}

/* ── COL 2: Service Links ── */
.footer__col--center {}
.footer__links {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.footer__links li a {
  font-size: 0.875rem;
  color: rgba(255,255,255,0.45);
  display: inline-flex;
  align-items: center;
  gap: 6px;
  transition: color 0.3s, gap 0.3s;
}
.footer__links li a::before {
  content: '›';
  color: var(--color-orange);
  font-size: 1.1rem;
  line-height: 1;
  opacity: 0.6;
  transition: opacity 0.3s, transform 0.3s;
}
.footer__links li a:hover {
  color: var(--color-white);
  gap: 10px;
}
.footer__links li a:hover::before {
  opacity: 1;
  transform: translateX(2px);
}

/* ── COL 3: Social Cards ── */
.social-cards {
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.social-card {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 14px;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 12px;
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}
.social-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(247,150,32,0.06), transparent);
  opacity: 0;
  transition: opacity 0.3s;
}
.social-card:hover {
  border-color: rgba(247,150,32,0.35);
  transform: translateX(4px);
}
.social-card:hover::before { opacity: 1; }
.social-card__icon {
  width: 36px; height: 36px;
  background: rgba(247,150,32,0.08);
  border: 1px solid rgba(247,150,32,0.2);
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  color: var(--color-orange);
  flex-shrink: 0;
  transition: background 0.3s;
}
.social-card:hover .social-card__icon { background: rgba(247,150,32,0.16); }
.social-card__info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.social-card__info strong {
  font-size: 0.85rem;
  font-weight: 700;
  color: rgba(255,255,255,0.8);
}
.social-card__info span {
  font-size: 0.72rem;
  color: rgba(255,255,255,0.35);
}
.social-card__arrow {
  color: rgba(255,255,255,0.2);
  flex-shrink: 0;
  transition: color 0.3s, transform 0.3s;
}
.social-card:hover .social-card__arrow {
  color: var(--color-orange);
  transform: translateX(3px);
}

/* ── BOTTOM BAR ── */
.footer__bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 0;
  flex-wrap: wrap;
  gap: 8px;
}
.footer__copy, .footer__built {
  font-size: 0.78rem;
  color: rgba(255,255,255,0.22);
}
.footer__built .orange { color: var(--color-orange); font-weight: 700; }

/* ── MARQUEE ── */
.footer__marquee-wrap {
  background: rgba(247,150,32,0.06);
  border-top: 1px solid rgba(247,150,32,0.12);
  padding: 18px 0;
  overflow: hidden;
  position: relative;
}
/* Fade edges */
.footer__marquee-wrap::before,
.footer__marquee-wrap::after {
  content: '';
  position: absolute;
  top: 0; bottom: 0;
  width: 120px;
  z-index: 2;
  pointer-events: none;
}
.footer__marquee-wrap::before {
  left: 0;
  background: linear-gradient(90deg, #050505, transparent);
}
.footer__marquee-wrap::after {
  right: 0;
  background: linear-gradient(270deg, #050505, transparent);
}

.footer__marquee {
  display: flex;
  overflow: hidden;
}
.footer__marquee-track {
  display: flex;
  align-items: center;
  gap: 40px;
  white-space: nowrap;
  animation: marquee-slide 18s linear infinite;
  will-change: transform;
}
.footer__marquee-track span {
  font-family: var(--font-primary);
  font-size: clamp(1.6rem, 4vw, 3rem);
  font-weight: 900;
  letter-spacing: -0.01em;
  text-transform: uppercase;
  color: transparent;
  -webkit-text-stroke: 1px rgba(247,150,32,0.35);
}
.footer__marquee-track span:hover {
  -webkit-text-stroke-color: rgba(247,150,32,0.7);
}
.marquee-dot {
  font-size: 1rem !important;
  -webkit-text-stroke: 0 !important;
  color: var(--color-orange) !important;
  opacity: 0.5;
}

@keyframes marquee-slide {
  0%   { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

/* ── RESPONSIVE ── */
@media (max-width: 900px) {
  .footer__grid {
    grid-template-columns: 1fr 1fr;
    gap: 36px;
  }
  .footer__col:first-child {
    grid-column: span 2;
  }
}
@media (max-width: 560px) {
  .footer__grid {
    grid-template-columns: 1fr;
    gap: 32px;
    padding: 40px 0 32px;
  }
  .footer__col:first-child { grid-column: span 1; }
  .footer__bottom { flex-direction: column; align-items: flex-start; }
}
</style>
