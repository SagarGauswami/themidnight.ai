---
---
<header class="navbar" id="navbar">
  <div class="container navbar__inner">
    <a href="/" class="navbar__logo">
      <img src="https://themidnight.in/media/images/logo.svg" alt="Midnight Digital" width="150" height="40" loading="eager" />
    </a>

    <nav class="navbar__links" id="navLinks">
      <a href="#services" class="nav-link">Services</a>
      <a href="#ai-products" class="nav-link">AI Products</a>
      <a href="#hire-devs" class="nav-link">Hire AI Devs</a>
      <a href="#why-us" class="nav-link">About</a>
      <a href="#contact" class="btn-primary nav-cta">Get Started <span>→</span></a>
    </nav>

    <button class="navbar__burger" id="burgerBtn" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
.navbar {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 1000;
  padding: 20px 0;
  transition: background 0.4s ease, padding 0.4s ease, box-shadow 0.4s ease;
}
.navbar.scrolled {
  background: rgba(9, 9, 9, 0.88);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  padding: 12px 0;
  box-shadow: 0 1px 0 rgba(247,150,32,0.15);
}
.navbar__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
}
.navbar__logo img {
  height: 38px;
  width: auto;
  filter: brightness(1.1);
  transition: filter 0.3s;
}
.navbar__logo:hover img { filter: brightness(1.3) drop-shadow(0 0 10px rgba(247,150,32,0.4)); }

.navbar__links {
  display: flex;
  align-items: center;
  gap: 36px;
}
.nav-link {
  font-size: 0.875rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  color: rgba(255,255,255,0.75);
  transition: color 0.3s;
  position: relative;
}
.nav-link::after {
  content: '';
  position: absolute;
  bottom: -4px; left: 0;
  width: 0; height: 2px;
  background: var(--color-orange);
  transition: width 0.3s;
}
.nav-link:hover { color: var(--color-white); }
.nav-link:hover::after { width: 100%; }

.nav-cta {
  padding: 10px 24px;
  font-size: 0.85rem;
  border-radius: 40px;
}

/* Burger */
.navbar__burger {
  display: none;
  flex-direction: column;
  gap: 5px;
  padding: 4px;
}
.navbar__burger span {
  display: block;
  width: 24px;
  height: 2px;
  background: var(--color-white);
  border-radius: 2px;
  transition: var(--transition);
}

@media (max-width: 768px) {
  .navbar__burger { display: flex; }
  .navbar__links {
    position: fixed;
    top: 0; right: -100%;
    width: 280px; height: 100vh;
    background: rgba(9,9,9,0.97);
    backdrop-filter: blur(20px);
    flex-direction: column;
    justify-content: center;
    gap: 32px;
    padding: 40px;
    border-left: 1px solid rgba(247,150,32,0.15);
    transition: right 0.4s cubic-bezier(0.4,0,0.2,1);
  }
  .navbar__links.open { right: 0; }
  .nav-link { font-size: 1.1rem; }
  .nav-cta { width: 100%; justify-content: center; }
}
</style>

<script>
const navbar = document.getElementById('navbar');
const burgerBtn = document.getElementById('burgerBtn');
const navLinks = document.getElementById('navLinks');

window.addEventListener('scroll', () => {
  if (window.scrollY > 60) {
    navbar?.classList.add('scrolled');
  } else {
    navbar?.classList.remove('scrolled');
  }
});

burgerBtn?.addEventListener('click', () => {
  navLinks?.classList.toggle('open');
});

navLinks?.querySelectorAll('a').forEach(link => {
  link.addEventListener('click', () => {
    navLinks.classList.remove('open');
  });
});
</script>
