---
---
<section class="hero" id="home">
  <canvas id="neural-canvas" class="hero__canvas"></canvas>

  <!-- Floating orbs -->
  <div class="hero__orb hero__orb--1"></div>
  <div class="hero__orb hero__orb--2"></div>
  <div class="hero__orb hero__orb--3"></div>

  <!-- Grid overlay -->
  <div class="hero__grid"></div>

  <div class="container hero__content">
    <div class="hero__badge">
      <span class="badge-dot"></span>
      AI-Powered Innovation
    </div>

    <h1 class="hero__headline">
      Powering the Future<br />
      <span class="gradient-text">with Artificial Intelligence</span>
    </h1>

    <p class="hero__subheadline">
      We build intelligent AI solutions, develop cutting-edge AI products for your business,
      and provide elite AI developers — <strong>on demand, on your terms.</strong>
    </p>

    <div class="hero__actions">
      <a href="#services" class="btn-primary">
        Explore AI Solutions
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a href="#hire-devs" class="btn-outline">
        Hire AI Developers
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
      </a>
    </div>
  </div>

  <!-- Floating AI chip visual -->
  <div class="hero__visual">
    <div class="chip-ring chip-ring--outer"></div>
    <div class="chip-ring chip-ring--mid"></div>
    <div class="chip-core">
      <svg width="52" height="52" viewBox="0 0 64 64" fill="none">
        <rect x="16" y="16" width="32" height="32" rx="4" stroke="#F79620" stroke-width="2" fill="rgba(247,150,32,0.08)"/>
        <rect x="22" y="22" width="20" height="20" rx="2" fill="rgba(247,150,32,0.15)" stroke="#F79620" stroke-width="1"/>
        <circle cx="32" cy="32" r="5" fill="#F79620"/>
        <line x1="8" y1="24" x2="16" y2="24" stroke="#F79620" stroke-width="2"/>
        <line x1="8" y1="32" x2="16" y2="32" stroke="#F79620" stroke-width="2"/>
        <line x1="8" y1="40" x2="16" y2="40" stroke="#F79620" stroke-width="2"/>
        <line x1="48" y1="24" x2="56" y2="24" stroke="#F79620" stroke-width="2"/>
        <line x1="48" y1="32" x2="56" y2="32" stroke="#F79620" stroke-width="2"/>
        <line x1="48" y1="40" x2="56" y2="40" stroke="#F79620" stroke-width="2"/>
        <line x1="24" y1="8" x2="24" y2="16" stroke="#F79620" stroke-width="2"/>
        <line x1="32" y1="8" x2="32" y2="16" stroke="#F79620" stroke-width="2"/>
        <line x1="40" y1="8" x2="40" y2="16" stroke="#F79620" stroke-width="2"/>
        <line x1="24" y1="48" x2="24" y2="56" stroke="#F79620" stroke-width="2"/>
        <line x1="32" y1="48" x2="32" y2="56" stroke="#F79620" stroke-width="2"/>
        <line x1="40" y1="48" x2="40" y2="56" stroke="#F79620" stroke-width="2"/>
      </svg>
    </div>
    <div class="orbit-dot orbit-dot--1"></div>
    <div class="orbit-dot orbit-dot--2"></div>
    <div class="orbit-dot orbit-dot--3"></div>
  </div>

  <div class="hero__scroll-hint">
    <div class="scroll-mouse"><div class="scroll-wheel"></div></div>
  </div>
</section>

<style>
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  overflow: hidden;
  padding-top: 100px;
}

/* Canvas */
.hero__canvas {
  position: absolute;
  inset: 0;
  width: 100%; height: 100%;
  z-index: 0;
  opacity: 0.45;
}

/* Grid */
.hero__grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(247,150,32,0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(247,150,32,0.04) 1px, transparent 1px);
  background-size: 60px 60px;
  z-index: 0;
  animation: grid-pulse 4s ease-in-out infinite;
}

/* Orbs */
.hero__orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  z-index: 0;
  pointer-events: none;
}
.hero__orb--1 {
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(247,150,32,0.18) 0%, transparent 70%);
  top: -100px; right: -100px;
  animation: float 8s ease-in-out infinite;
}
.hero__orb--2 {
  width: 350px; height: 350px;
  background: radial-gradient(circle, rgba(247,150,32,0.1) 0%, transparent 70%);
  bottom: 100px; left: -80px;
  animation: float 10s ease-in-out infinite reverse;
}
.hero__orb--3 {
  width: 200px; height: 200px;
  background: radial-gradient(circle, rgba(247,150,32,0.14) 0%, transparent 70%);
  top: 40%; right: 30%;
  animation: float 6s ease-in-out infinite 2s;
}

/* Content */
.hero__content {
  position: relative;
  z-index: 2;
  max-width: 680px;
  animation: fade-in-up 0.9s ease forwards;
}

.hero__badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 7px 18px;
  background: rgba(247,150,32,0.1);
  border: 1px solid rgba(247,150,32,0.3);
  border-radius: 40px;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-orange);
  margin-bottom: 28px;
}
.badge-dot {
  width: 7px; height: 7px;
  background: var(--color-orange);
  border-radius: 50%;
  animation: pulse-glow 2s ease-in-out infinite;
}

.hero__headline {
  margin-bottom: 24px;
  font-weight: 900;
  letter-spacing: -0.02em;
}
.hero__subheadline {
  font-size: 1.1rem;
  color: rgba(255,255,255,0.65);
  line-height: 1.75;
  margin-bottom: 40px;
  max-width: 560px;
}
.hero__subheadline strong { color: var(--color-orange); font-weight: 600; }

.hero__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  margin-bottom: 0;
}

/* Floating chip visual */
.hero__visual {
  position: absolute;
  right: 8%;
  top: 50%;
  transform: translateY(-50%);
  z-index: 2;
  width: 260px; height: 260px;
  display: flex; align-items: center; justify-content: center;
  animation: float 6s ease-in-out infinite;
}
.chip-ring {
  position: absolute;
  border-radius: 50%;
  border: 1px solid rgba(247,150,32,0.25);
}
.chip-ring--outer {
  width: 240px; height: 240px;
  animation: spin-slow 18s linear infinite;
  border-style: dashed;
}
.chip-ring--mid {
  width: 170px; height: 170px;
  animation: spin-slow 12s linear infinite reverse;
}
.chip-core {
  width: 100px; height: 100px;
  background: rgba(247,150,32,0.06);
  border: 1px solid rgba(247,150,32,0.4);
  border-radius: 16px;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 0 40px rgba(247,150,32,0.2), inset 0 0 20px rgba(247,150,32,0.05);
  animation: pulse-glow 3s ease-in-out infinite;
}
.orbit-dot {
  position: absolute;
  width: 10px; height: 10px;
  background: var(--color-orange);
  border-radius: 50%;
  box-shadow: 0 0 12px var(--color-orange);
}
.orbit-dot--1 { animation: orbit 6s linear infinite; }
.orbit-dot--2 { animation: orbit 9s linear infinite reverse; opacity: 0.6; }
.orbit-dot--3 { animation: orbit 12s linear infinite 3s; opacity: 0.4; width: 6px; height: 6px; }

/* Scroll hint */
.hero__scroll-hint {
  position: absolute;
  bottom: 36px; left: 50%;
  transform: translateX(-50%);
  z-index: 2;
  display: flex; flex-direction: column; align-items: center; gap: 8px;
}
.scroll-mouse {
  width: 22px; height: 34px;
  border: 2px solid rgba(255,255,255,0.3);
  border-radius: 12px;
  display: flex; justify-content: center; padding-top: 6px;
}
.scroll-wheel {
  width: 3px; height: 8px;
  background: var(--color-orange);
  border-radius: 2px;
  animation: float 1.5s ease-in-out infinite;
}

@media (max-width: 1024px) {
  .hero__visual { width: 180px; height: 180px; right: 3%; }
  .chip-ring--outer { width: 170px; height: 170px; }
  .chip-ring--mid { width: 120px; height: 120px; }
  .chip-core { width: 80px; height: 80px; }
}
@media (max-width: 768px) {
  .hero__visual { display: none; }
  .hero__content { max-width: 100%; }
}
</style>

<script>
// Neural network canvas animation
const canvas = document.getElementById('neural-canvas') as HTMLCanvasElement;
const ctx = canvas?.getContext('2d');

if (canvas && ctx) {
  let w = canvas.width = window.innerWidth;
  let h = canvas.height = window.innerHeight;

  interface Node {
    x: number; y: number;
    vx: number; vy: number;
    r: number;
  }

  const nodes: Node[] = [];
  const count = Math.min(80, Math.floor((w * h) / 14000));

  for (let i = 0; i < count; i++) {
    nodes.push({
      x: Math.random() * w,
      y: Math.random() * h,
      vx: (Math.random() - 0.5) * 0.4,
      vy: (Math.random() - 0.5) * 0.4,
      r: Math.random() * 2 + 1
    });
  }

  function draw() {
    if (!ctx) return;
    ctx.clearRect(0, 0, w, h);

    // Move nodes
    for (const n of nodes) {
      n.x += n.vx;
      n.y += n.vy;
      if (n.x < 0 || n.x > w) n.vx *= -1;
      if (n.y < 0 || n.y > h) n.vy *= -1;
    }

    // Draw connections
    for (let i = 0; i < nodes.length; i++) {
      for (let j = i + 1; j < nodes.length; j++) {
        const dx = nodes[i].x - nodes[j].x;
        const dy = nodes[i].y - nodes[j].y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < 150) {
          ctx.beginPath();
          ctx.moveTo(nodes[i].x, nodes[i].y);
          ctx.lineTo(nodes[j].x, nodes[j].y);
          ctx.strokeStyle = `rgba(247,150,32,${0.18 * (1 - dist / 150)})`;
          ctx.lineWidth = 0.8;
          ctx.stroke();
        }
      }
    }

    // Draw nodes
    for (const n of nodes) {
      ctx.beginPath();
      ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(247,150,32,0.55)';
      ctx.fill();
    }

    requestAnimationFrame(draw);
  }
  draw();

  window.addEventListener('resize', () => {
    w = canvas.width = window.innerWidth;
    h = canvas.height = window.innerHeight;
  });
}
</script>
