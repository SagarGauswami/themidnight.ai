---
---
<section class="cta-section section" id="contact">
  <div class="cta-section__glow"></div>
  <div class="container cta-section__inner">
    <div class="cta-left">
      <div class="section-label">Let's Build Together</div>
      <h2>Ready to Transform<br /><span class="gradient-text">Your Business with AI?</span></h2>
      <p class="cta-desc">
        Whether you need a custom AI solution, a full product build, or elite AI developers —
        we're one conversation away. Let's make it happen.
      </p>
      <div class="cta-contacts">
        <a href="mailto:sagar@themidnight.in" class="cta-contact-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#F79620" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          sagar@themidnight.in
        </a>
        <a href="https://themidnight.in" target="_blank" class="cta-contact-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#F79620" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15 15 0 0 1 0 20M12 2a15 15 0 0 0 0 20"/></svg>
          themidnight.in
        </a>
      </div>
    </div>

    <div class="cta-form-card glass-card">
      <h4 class="form-title">Get a Free AI Consultation</h4>
      <form class="cta-form" id="ctaForm">
        <div class="form-row">
          <div class="form-group">
            <label for="name">Your Name</label>
            <input type="text" id="name" name="name" placeholder="Rahul Verma" required />
          </div>
          <div class="form-group">
            <label for="phone">Phone Number</label>
            <input type="tel" id="phone" name="phone" placeholder="+91 98765 43210" />
          </div>
        </div>
        <div class="form-group">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email" placeholder="rahul@company.com" required />
        </div>
        <div class="form-group">
          <label for="service">What do you need?</label>
          <select id="service" name="service">
            <option value="">Select a service</option>
            <option value="AI Solutions / ML">AI Solutions / ML</option>
            <option value="AI Product Development">AI Product Development</option>
            <option value="Hire AI Developers">Hire AI Developers</option>
            <option value="AI Strategy Consulting">AI Strategy Consulting</option>
          </select>
        </div>
        <div class="form-group">
          <label for="message">Tell us about your project</label>
          <textarea id="message" name="message" rows="3" placeholder="Brief description of your AI project..."></textarea>
        </div>
        <button type="submit" class="btn-primary form-submit" id="submitBtn">
          Send Message
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </button>
      </form>
    </div>
  </div>
</section>

<style>
.cta-section {
  position: relative;
  overflow: hidden;
}
.cta-section__glow {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 600px; height: 400px;
  background: radial-gradient(ellipse, rgba(247,150,32,0.1) 0%, transparent 70%);
  pointer-events: none;
}
.cta-section__inner {
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 64px;
  align-items: start;
}
.cta-desc {
  font-size: 1rem;
  color: rgba(255,255,255,0.55);
  line-height: 1.8;
  margin: 20px 0 32px;
}
.cta-contacts {
  display: flex;
  flex-direction: column;
  gap: 14px;
}
.cta-contact-item {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-size: 0.9rem;
  font-weight: 600;
  color: rgba(255,255,255,0.65);
  transition: color 0.3s;
}
.cta-contact-item:hover { color: var(--color-orange); }

/* Form */
.cta-form-card { padding: 36px; }
.form-title {
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--color-white);
  margin-bottom: 24px;
  padding-bottom: 16px;
  border-bottom: 1px solid var(--color-border);
}
.cta-form {
  display: flex;
  flex-direction: column;
  gap: 14px;
}
.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
}
.form-group {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.form-group label {
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--color-text-muted);
}
.form-group input,
.form-group select,
.form-group textarea {
  background: rgba(255,255,255,0.04);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  padding: 11px 14px;
  font-family: var(--font-secondary);
  font-size: 0.875rem;
  color: var(--color-white);
  transition: border-color 0.3s, box-shadow 0.3s;
  outline: none;
  width: 100%;
  resize: vertical;
}
.form-group input::placeholder,
.form-group textarea::placeholder { color: rgba(255,255,255,0.2); }
.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus {
  border-color: var(--color-orange);
  box-shadow: 0 0 0 3px rgba(247,150,32,0.08);
}
.form-group select option { background: #1a1a1a; color: #fff; }
.form-submit {
  width: 100%;
  justify-content: center;
  margin-top: 4px;
  transition: all 0.3s;
}

@media (max-width: 900px) {
  .cta-section__inner { grid-template-columns: 1fr; gap: 40px; }
}
@media (max-width: 480px) {
  .form-row { grid-template-columns: 1fr; }
}
</style>

<script>
document.getElementById('ctaForm')?.addEventListener('submit', function(e) {
  e.preventDefault();

  const nameVal    = (document.getElementById('name') as HTMLInputElement)?.value || '';
  const phoneVal   = (document.getElementById('phone') as HTMLInputElement)?.value || '';
  const emailVal   = (document.getElementById('email') as HTMLInputElement)?.value || '';
  const serviceVal = (document.getElementById('service') as HTMLSelectElement)?.value || '';
  const msgVal     = (document.getElementById('message') as HTMLTextAreaElement)?.value || '';

  const subject = encodeURIComponent(`New AI Enquiry from ${nameVal} — ${serviceVal || 'General'}`);
  const body = encodeURIComponent(
    `Hello Sagar,\n\nYou have received a new lead from the Midnight Digital website.\n\n` +
    `Name:    ${nameVal}\n` +
    `Phone:   ${phoneVal || 'Not provided'}\n` +
    `Email:   ${emailVal}\n` +
    `Service: ${serviceVal || 'Not specified'}\n\n` +
    `Message:\n${msgVal}\n\n` +
    `---\nSent from themidnight.ai contact form`
  );

  const to  = 'sagar@themidnight.in';
  const cc  = encodeURIComponent('sagar@runr.in,mr.sagar.gauswami@gmail.com');
  const mailtoLink = `mailto:${to}?cc=${cc}&subject=${subject}&body=${body}`;

  window.location.href = mailtoLink;

  // Show success state
  const btn = document.getElementById('submitBtn') as HTMLButtonElement;
  if (btn) {
    const original = btn.innerHTML;
    btn.innerHTML = '✓ Opening Email Client...';
    btn.style.background = '#22c55e';
    setTimeout(() => {
      btn.innerHTML = original;
      btn.style.background = '';
      (e.target as HTMLFormElement).reset();
    }, 3000);
  }
});
</script>
